class Car  {
    String brand;
    String model;
    String price;
    public void displayCar(){
        System.out.println("Name:" +brand);
        System.out.println("Model:"+model);
        System.out.println("Price:"+price);
    }
    Car(String brand,String model,String price){
        this.brand=brand;
        this.model=model;
        this.price=price;
    }  
}
public class Lab4Task1 {
    public static void main(String[] args) {
        Car car1=new Car("Toyota", "Coralla","$22,000 USD");
        car1.displayCar();
    }
}
